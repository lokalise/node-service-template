# Overrides on top of .env.default for Docker healthcheck test.
# Hostnames point to compose service names instead of localhost.
# JWT key flattened to single line (docker --env-file can't parse multiline values).
NODE_ENV=production
APP_ENV=production
DATABASE_URL=postgresql://serviceuser:pass@postgres:5432/service_db?application_name=new_service
REDIS_HOST=redis
SCHEDULER_REDIS_HOST=redis
AMQP_HOSTNAME=rabbitmq
AWS_ENDPOINT=http://fauxqs:4566
AWS_SNS_ENDPOINT=http://fauxqs:4566
AWS_SQS_ENDPOINT=http://fauxqs:4566
