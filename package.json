{
    "name": "node-service-template",
    "version": "1.13.0",
    "engines": {
        "node": ">=24.16.0"
    },
    "packageManager": "pnpm@11.2.2",
    "type": "module",
    "scripts": {
        "build": "pnpm --filter @node-service-template/api-contracts run build && tsc -p tsconfig.build.json",
        "build:service": "tsc -p tsconfig.build.json",
        "build:contracts": "pnpm --filter @node-service-template/api-contracts run build",
        "copy:config": "cpy --rename=.env ./.env.default ./",
        "test": "vitest",
        "test:migrate": "cross-env NODE_ENV=test DATABASE_URL=postgres://serviceuser:pass@localhost:5432/service_db_test pnpm exec drizzle-kit migrate --config=./src/db/drizzle.config.ts",
        "test:coverage": "node --run test -- --coverage",
        "test:ci": "node --run copy:config && node --run test:migrate && node --run test:coverage",
        "lint": "biome check . && tsc && pnpm --filter \"./packages/*\" run lint && pnpm run docs:validate",
        "lint:fix": "biome check --write . && pnpm --filter \"./packages/*\" run lint:fix",
        "start:dev": "node --run build:contracts && node --env-file=.env src/server.ts",
        "start:dev:watch": "node --run build:contracts && node --watch --env-file=.env src/server.ts",
        "start:prod": "node --run build && cross-env NODE_ENV=production node --env-file-if-exists=.env dist/server.js",
        "start:prod:opentelemetry": "node --run build && cross-env NODE_ENV=production node --import=@opentelemetry/instrumentation/hook.mjs --env-file-if-exists=.env dist/server.js",
        "free-ports": "pnpm dlx cross-port-killer 3000",
        "docker:start:dev": "docker compose up -d --quiet-pull --wait",
        "docker:stop:dev": "docker compose down",
        "db:generate-migrations": "cross-env NODE_ENV=development pnpm exec drizzle-kit generate --config=./src/db/drizzle.config.ts",
        "db:apply-migrations": "cross-env NODE_ENV=development pnpm exec drizzle-kit migrate --config=./src/db/drizzle.config.ts",
        "db:drop-migrations": "cross-env NODE_ENV=development pnpm exec drizzle-kit drop --config=./src/db/drizzle.config.ts",
        "spec:generate": "node --env-file-if-exists=.env  scripts/generateOpenApi.ts",
        "docs:generate": "envase generate ./src/infrastructure/config.ts -o ./docs/environment-variables.md",
        "docs:validate": "envase validate ./src/infrastructure/config.ts ./docs/environment-variables.md",
        "prepublishOnly": "node --run build",
        "jwt:generate": "node --env-file-if-exists=.env scripts/generateJwt.ts",
        "cmd:getUserImportJobs": "node --env-file-if-exists=.env scripts/cmd/getUserImportJobs.ts"
    },
    "dependencies": {
        "@aws-sdk/client-sns": "^3.1053.0",
        "@aws-sdk/client-sqs": "^3.1053.0",
        "@aws-sdk/client-sts": "^3.1053.0",
        "@aws-sdk/credential-providers": "^3.1053.0",
        "@fastify/auth": "^5.0.4",
        "@fastify/awilix": "^8.2.0",
        "@fastify/cors": "^11.2.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/jwt": "^10.1.0",
        "@fastify/otel": "0.18.1",
        "@fastify/schedule": "^6.0.0",
        "@fastify/swagger": "^9.7.0",
        "@lokalise/api-contracts": "^6.11.0",
        "@lokalise/aws-config": "^8.1.0",
        "@lokalise/backend-http-client": "^11.1.0",
        "@lokalise/background-jobs-common": "^14.4.0",
        "@lokalise/fastify-api-contracts": "^5.3.1",
        "@lokalise/fastify-extras": "^31.0.0",
        "@lokalise/healthcheck-utils": "^6.0.0",
        "@lokalise/node-core": "^14.8.1",
        "@lokalise/opentelemetry-fastify-bootstrap": "^3.0.0",
        "@lokalise/universal-ts-utils": "^4.10.0",
        "@lokalise/zod-extras": "^3.0.2",
        "@message-queue-toolkit/amqp": "^24.1.0",
        "@message-queue-toolkit/core": "^26.0.0",
        "@message-queue-toolkit/metrics": "^4.4.2",
        "@message-queue-toolkit/schemas": "^7.1.0",
        "@message-queue-toolkit/sns": "^26.1.0",
        "@message-queue-toolkit/sqs": "^26.0.0",
        "@node-service-template/api-contracts": "workspace:*",
        "@opentelemetry/auto-instrumentations-node": "0.76.0",
        "@opentelemetry/exporter-trace-otlp-grpc": "0.218.0",
        "@opentelemetry/instrumentation": "^0.218.0",
        "@scalar/fastify-api-reference": "^1.57.5",
        "amqplib": "^2.0.1",
        "awilix": "^13.0.3",
        "awilix-manager": "^7.0.0",
        "bullmq": "^5.77.3",
        "drizzle-kit": "1.0.0-rc.4-273829f",
        "drizzle-orm": "1.0.0-rc.4-273829f",
        "envase": "^1.5.0",
        "fastify": "^5.8.5",
        "fastify-graceful-shutdown": "^5.0.0",
        "fastify-metrics": "^13.2.0",
        "fastify-no-icon": "^7.0.0",
        "fastify-plugin": "^5.1.0",
        "fastify-type-provider-zod": "^6.1.0",
        "ioredis": "^5.10.1",
        "layered-loader": "^14.3.1",
        "opinionated-machine": "^6.20.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "postgres": "^3.4.9",
        "prom-client": "^15.1.3",
        "redis-semaphore": "^5.7.0",
        "toad-scheduler": "^4.0.1",
        "undici": "^8.3.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@amplitude/analytics-types": "^2.11.1",
        "@biomejs/biome": "2.4.16",
        "@lokalise/biome-config": "^3.1.1",
        "@lokalise/tsconfig": "^4.0.0",
        "@lokalise/universal-testing-utils": "^3.6.0",
        "@opentelemetry/sdk-trace-base": "^2.7.1",
        "@readme/openapi-parser": "^6.1.1",
        "@types/amqplib": "^0.10.8",
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^4.1.7",
        "cpy-cli": "^7.0.0",
        "cross-env": "^10.1.0",
        "fast-jwt": "^6.2.4",
        "fauxqs": "^2.6.0",
        "mockttp": "^4.4.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7",
        "yaml": "^2.9.0"
    },
    "optionalDependencies": {
        "@biomejs/cli-darwin-arm64": "^2.4.16",
        "@biomejs/cli-linux-arm64": "^2.4.16",
        "@biomejs/cli-linux-x64": "^2.4.16",
        "@biomejs/cli-win32-x64": "^2.4.16",
        "@esbuild/darwin-arm64": "^0.28.0",
        "@esbuild/linux-arm64": "^0.28.0",
        "@esbuild/linux-x64": "^0.28.0",
        "@esbuild/win32-x64": "^0.28.0"
    }
}
